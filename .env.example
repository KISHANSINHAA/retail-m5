# RetailSense AI Configuration Template
# Rename this file to '.env' and fill in your details

# LLM API CONFIGURATION
# To use Groq (Default):
LLM_API_KEY=your_groq_api_key_here
LLM_API_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile

# To use Grok (x.ai):
# LLM_API_KEY=your_grok_api_key_here
# LLM_API_URL=https://api.x.ai/v1
# LLM_MODEL_NAME=grok-2-1212

# ETL & SPARK PARAMETERS
# Number of items to sample from sales data for fast local testing.
# Set to 0 to run the entire dataset, which can take considerable memory/time locally.
SAMPLE_LIMIT=100

# API SERVER CONFIGURATION
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://localhost:8000
